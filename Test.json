KW_Count_Test = 
VAR SelectedDomain = SELECTEDVALUE(Dim_Domain[Domain])

-- 🔹 Numerator (Top 10 based on selected domain)
RETURN
    SWITCH(
        SelectedDomain,

       "Dell",
        CALCULATE(
            DISTINCTCOUNT('SoV_Generic_Data'[Keyword]),
            NOT ISBLANK('SoV_Generic_Data'[www.dell.com/en-us: Position]),
            'SoV_Generic_Data'[www.dell.com/en-us: Position] <= 10
        ),

        "HP",
        CALCULATE(
                DISTINCTCOUNT('SoV_Generic_Data'[Keyword]),
                NOT ISBLANK('SoV_Generic_Data'[hp.com/us-en/home.html: Position]),
